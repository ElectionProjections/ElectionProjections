<script>
(function(){
  const SEATS=630, MAJ=Math.floor(SEATS/2)+1, K=BASE.keys;
  const META={
    cdu:{n:'CDU',t:'Christlich Demokratische Union',c:'#4A4A46'},
    csu:{n:'CSU',t:'Christlich-Soziale Union',c:'#2C5F7C'},
    afd:{n:'AfD',t:'Alternative für Deutschland',c:'#3D8BDB'},
    spd:{n:'SPD',t:'Sozialdemokraten',c:'#DE3B39'},
    gru:{n:'Grüne',t:'Bündnis 90/Die Grünen',c:'#5E9421'},
    lin:{n:'Linke',t:'Die Linke',c:'#CE4B79'},
    bsw:{n:'BSW',t:'Bündnis Sahra Wagenknecht',c:'#7A72D6'},
    fdp:{n:'FDP',t:'Freie Demokraten',c:'#E8A118'},
    fw:{n:'Freie Wähler',t:'Freie Wähler',c:'#1B9A72'},
    ssw:{n:'SSW',t:'Minderheitenpartei',c:'#7E7E77'}
  };
  const INPUT=['union','afd','spd','gru','lin','bsw','fdp','fw','ssw'];
  const OUT=['cdu','csu','afd','spd','gru','lin','bsw','fdp','fw','ssw'];
  const LR={lin:1,spd:2,gru:3,ssw:4,bsw:5,fw:6,fdp:7,cdu:8,csu:9,afd:10};
  const IN_META={union:{n:'CDU/CSU',t:'Union',c:'#4A4A46'}};
  INPUT.forEach(k=>{ if(!IN_META[k]) IN_META[k]=META[k]; });

  const WK=BASE.wk.map(r=>{const o={land:r[2],s:{}};K.forEach((k,i)=>o.s[k]=r[4+i]/r[3]*100);return o;});
  const LAND=BASE.laender.map(l=>{const o={id:l[0],name:l[1],valid:l[2],s:{}};K.forEach((k,i)=>o.s[k]=l[3+i]);return o;});
  const TOTV=LAND.reduce((a,l)=>a+l.valid,0);
  const P=INPUT.map(k=>({k,...IN_META[k],v:+BASE.bund[k].toFixed(2),base:BASE.bund[k]}));
  const DEF=P.map(p=>p.v);
  const coal=new Set();
  let area='DE';

  const sel=document.getElementById('area');
  sel.innerHTML='<option value="DE">Germany</option>'+LAND.map(l=>'<option value="'+l.id+'">'+l.name+'</option>').join('');

  const rows=document.getElementById('rows');
  P.forEach((p,i)=>{
    const r=document.createElement('div');
    r.className='prow'; r.dataset.k=p.k;
    r.innerHTML='<span class="swatch" style="background:'+p.c+'"></span>'+
      '<span class="pname">'+p.n+'<small>'+p.t+'</small></span>'+
      '<span class="num"><label class="sr" for="n-'+p.k+'">'+p.n+' second-vote share</label>'+
      '<input id="n-'+p.k+'" class="nm" data-i="'+i+'" type="number" min="0" max="100" step="0.01" value="'+p.v.toFixed(2)+'"><span>%</span></span>'+
      '<span class="wk" id="wk-'+p.k+'"><b>0</b></span>'+
      '<input class="sl" data-i="'+i+'" type="range" min="0" max="50" step="0.1" value="'+p.v+'" aria-label="'+p.n+' slider">';
    rows.appendChild(r);
  });

  function sl(w,total){
    const s=w.map(()=>0), q=w.map(x=>x/0.5);
    for(let i=0;i<total;i++){
      let b=0; for(let j=1;j<q.length;j++) if(q[j]>q[b]) b=j;
      if(q[b]<=0) break;
      s[b]++; q[b]=w[b]/(s[b]+0.5);
    }
    return s;
  }

  function project(){
    const sw={}; P.forEach(p=>sw[p.k]=p.v-p.base);

    const landVotes={};
    OUT.forEach(k=>landVotes[k]={});
    LAND.forEach(l=>{
      INPUT.forEach(k=>{
        const share=Math.max(0,l.s[k]+sw[k]);
        const votes=share/100*l.valid;
        if(k==='union'){ landVotes[l.id==='BY'?'csu':'cdu'][l.id]=votes; }
        else landVotes[k][l.id]=votes;
      });
    });

    const nat={};
    OUT.forEach(k=>{ nat[k]=Object.values(landVotes[k]).reduce((a,b)=>a+b,0)/TOTV*100; });

    const direct={}; OUT.forEach(k=>direct[k]={});
    for(const c of WK){
      let b=null,bv=-1;
      for(const k of INPUT){ const x=Math.max(0,c.s[k]+sw[k]); if(x>bv){bv=x;b=k;} }
      const key = b==='union' ? (c.land==='BY'?'csu':'cdu') : b;
      direct[key][c.land]=(direct[key][c.land]||0)+1;
    }
    const wins={}; OUT.forEach(k=>wins[k]=Object.values(direct[k]).reduce((a,b)=>a+b,0));

    const qual=OUT.filter(k=>nat[k]>0.0001 && (nat[k]>=5 || k==='ssw' || wins[k]>=3));
    const seats=qual.length?sl(qual.map(k=>nat[k]),SEATS):[];
    const R={};
    qual.forEach((k,i)=>{
      const w=LAND.map(l=>landVotes[k][l.id]||0);
      const per=sl(w,seats[i]);
      const e={k,...META[k],share:nat[k],total:seats[i],direct:0,list:0,uncovered:0,byLand:{}};
      LAND.forEach((l,j)=>{
        const s=per[j], d=direct[k][l.id]||0, seated=Math.min(d,s);
        e.byLand[l.id]={seats:s,direct:seated,list:s-seated,uncovered:d-seated,
                        share:(landVotes[k][l.id]||0)/l.valid*100};
        e.direct+=seated; e.list+=s-seated; e.uncovered+=d-seated;
      });
      R[k]=e;
    });
    OUT.forEach(k=>{ if(!R[k] && wins[k]) R[k]={k,...META[k],share:nat[k],total:0,direct:0,list:0,uncovered:wins[k],byLand:{}}; });
    return {R,wins,nat};
  }

  function view(R){
    return Object.values(R).filter(e=>e.total>0).map(e=>{
      if(area==='DE') return {...e,s:e.total,d:e.direct,l:e.list,u:e.uncovered};
      const b=e.byLand[area]||{seats:0,direct:0,list:0,uncovered:0,share:0};
      return {...e,s:b.seats,d:b.direct,l:b.list,u:b.uncovered,share:b.share};
    }).filter(e=>e.s>0).sort((a,b)=>b.s-a.s);
  }

  function drawArc(res){
    const seated=[...res].sort((a,b)=>LR[a.k]-LR[b.k]);
    const flat=[]; seated.forEach(p=>{for(let i=0;i<p.s;i++) flat.push(p);});
    const cx=340,cy=318,n=flat.length;
    const ROWS=Math.max(3,Math.min(13,Math.round(Math.sqrt(n/3.6))));
    let out='<title id="arc-t">Hemicycle: '+n+' seats</title>';
    if(n){
      const radii=[]; for(let r=0;r<ROWS;r++) radii.push(110+r*(196/Math.max(1,ROWS-1)));
      const ws=radii.reduce((a,b)=>a+b,0);
      const counts=radii.map(rad=>Math.floor(n*rad/ws));
      const rem=n-counts.reduce((a,b)=>a+b,0);
      const frac=radii.map((rad,r)=>({r,f:(n*rad/ws)%1})).sort((a,b)=>b.f-a.f);
      for(let i=0;i<rem;i++) counts[frac[i%ROWS].r]++;
      const pos=[];
      for(let r=0;r<ROWS;r++){
        const rad=radii[r],c=counts[r];
        for(let j=0;j<c;j++){
          const t=(c===1)?0.5:j/(c-1), a=Math.PI-t*Math.PI;
          pos.push({x:cx+rad*Math.cos(a),y:cy-rad*Math.sin(a),a,rad});
        }
      }
      pos.sort((p1,p2)=>p2.a===p1.a?p1.rad-p2.rad:p2.a-p1.a);
      const r=Math.max(3,Math.min(6.5,240/Math.sqrt(n*3)));
      pos.forEach((q,i)=>{
        const p=flat[i], dim=coal.size&&!coal.has(p.k);
        out+='<circle class="seat" cx="'+q.x.toFixed(1)+'" cy="'+q.y.toFixed(1)+'" r="'+r.toFixed(1)+'" fill="'+p.c+'" opacity="'+(dim?0.22:1)+'"></circle>';
      });
    }
    document.getElementById('arc').innerHTML=out;
  }

  function drawCoalition(res,pool){
    document.getElementById('chips').innerHTML=res.map(p=>
      '<button class="chip" type="button" data-k="'+p.k+'" aria-pressed="'+coal.has(p.k)+'">'+
      '<i style="background:'+p.c+'"></i>'+p.n+' &middot; '+p.s+'</button>').join('');
    const picked=res.filter(p=>coal.has(p.k));
    const sum=picked.reduce((a,p)=>a+p.s,0);
    document.getElementById('fill').innerHTML=picked.map(p=>
      '<span style="width:'+(p.s/pool*100)+'%;background:'+p.c+'"></span>').join('');
    const note=document.getElementById('coalnote');
    if(!picked.length){ note.textContent='Select parties to test a majority.'; return; }
    if(area!=='DE'){ note.innerHTML='<b>'+sum+'</b> of '+pool+' seats in this Land'; return; }
    const d=sum-MAJ;
    note.innerHTML='<b>'+sum+'</b> of '+SEATS+' seats &middot; '+(d>=0?'majority with '+d+' to spare':(MAJ-sum)+' short of '+MAJ);
  }

  function drawMap(R){
    const svg=document.getElementById('map');
    let out='';
    LAND.forEach(l=>{
      const runners=Object.values(R).filter(e=>e.byLand[l.id] && e.byLand[l.id].seats>0)
        .map(e=>({k:e.k,n:e.n,c:e.c,s:e.byLand[l.id].seats,v:e.byLand[l.id].share}))
        .sort((a,b)=> b.s-a.s || b.v-a.v);
      const top=runners[0];
      const tied=top && runners[1] && runners[1].s===top.s;
      const fill=top?top.c:'#D8D8D2';
      out+='<path d="'+MAP[l.id]+'" fill="'+fill+'" class="'+(area===l.id?'sel':'')+'" data-l="'+l.id+'">'+
        '<title>'+l.name+(top?' — '+top.n+', '+top.s+' of '+runners.reduce((a,r)=>a+r.s,0)+' seats'+
        (tied?' (tied on seats, ahead on votes)':''):'')+'</title></path>';
    });
    svg.innerHTML=out;
  }

  function render(){
    const {R,wins,nat}=project();
    const res=view(R);
    const total=P.reduce((a,p)=>a+p.v,0);
    const areaName=area==='DE'?'Germany':LAND.find(l=>l.id===area).name;
    const pool=res.reduce((a,p)=>a+p.s,0);
    const unfilled=Object.values(R).reduce((a,e)=>a+e.uncovered,0);

    P.forEach(p=>{
      const keys = p.k==='union' ? ['cdu','csu'] : [p.k];
      const seatsSum = keys.reduce((a,k)=>a+(R[k]?R[k].total:0),0);
      const winSum = keys.reduce((a,k)=>a+wins[k],0);
      const row=rows.querySelector('.prow[data-k="'+p.k+'"]');
      row.classList.toggle('out', p.v>0 && seatsSum===0);
      const clause = keys.some(k=>R[k] && R[k].total>0 && nat[k]<5 && k!=='ssw' && wins[k]>=3);
      const cell=document.getElementById('wk-'+p.k);
      cell.className='wk'+(clause?' clause':'');
      cell.innerHTML='<b>'+winSum+'</b>'+(clause?'clause met':'');
    });

    document.getElementById('seated').textContent=SEATS;
    document.getElementById('seated-note').textContent='of '+SEATS+' seats · majority '+MAJ;

    const tally=document.getElementById('tally');
    document.getElementById('tally-text').textContent='Total '+total.toFixed(2)+'%'+(total>100.05?' — over 100':'');
    tally.classList.toggle('warn',total>100.05);

    document.getElementById('bd').innerHTML=res.map(p=>
      '<tr><td><i style="background:'+p.c+'"></i>'+p.n+'</td><td>'+p.share.toFixed(2)+'</td><td><b>'+p.s+'</b></td><td>'+p.d+'</td><td>'+p.l+'</td></tr>').join('')+
      '<tr class="sum"><td>'+areaName+'</td><td></td><td>'+pool+'</td><td>'+res.reduce((a,p)=>a+p.d,0)+'</td><td>'+res.reduce((a,p)=>a+p.l,0)+'</td></tr>';

    const missed=OUT.filter(k=>nat[k]>0.0001 && !(R[k]&&R[k].total>0));
    const saved=OUT.filter(k=>R[k]&&R[k].total>0 && nat[k]<5 && k!=='ssw' && wins[k]>=3);
    const lost=missed.reduce((a,k)=>a+nat[k],0);
    document.getElementById('clause-line').innerHTML=missed.length
      ? 'No seats: <b>'+missed.map(k=>META[k].n+' '+nat[k].toFixed(2)+'%').join(', ')+'</b> — '+lost.toFixed(2)+'% of votes discarded'
      : 'Threshold: <b>every listed party wins seats</b>';
    const flip=document.getElementById('flip');
    const bits=[];
    saved.forEach(k=>bits.push('<b>'+META[k].n+'</b> is on '+nat[k].toFixed(2)+'% but holds '+wins[k]+' constituencies, so the basic-mandate clause admits it at full strength.'));
    if(unfilled) bits.push('<b>'+unfilled+'</b> constituenc'+(unfilled===1?'y goes':'ies go')+' unfilled for want of second-vote coverage.');
    flip.className='flip'+(saved.length?' flag':'');
    flip.innerHTML=bits.join('<br>');

    const lab=document.getElementById('maplab');
    if(area==='DE') lab.innerHTML='Click a Land to filter the breakdown.';
    else{
      const top=res[0];
      lab.innerHTML='<b>'+areaName+'</b> · '+pool+' seats · largest: '+(top?top.n:'—');
    }

    for(const k of [...coal]) if(!res.some(p=>p.k===k)) coal.delete(k);
    drawMap(R);
    drawArc(res);
    drawCoalition(res, area==='DE'?SEATS:pool);
  }

  rows.addEventListener('input',e=>{
    const i=+e.target.dataset.i; if(Number.isNaN(i)) return;
    let v=parseFloat(e.target.value); if(!isFinite(v)) v=0;
    v=Math.max(0,Math.min(100,Math.round(v*100)/100));
    P[i].v=v;
    rows.querySelector('.sl[data-i="'+i+'"]').value=Math.min(50,v);
    if(e.target.classList.contains('sl')) rows.querySelector('.nm[data-i="'+i+'"]').value=v.toFixed(2);
    render();
  });
  sel.addEventListener('change',e=>{ area=e.target.value; render(); });
  document.getElementById('map').addEventListener('click',e=>{
    const p=e.target.closest('path'); if(!p) return;
    area = (area===p.dataset.l) ? 'DE' : p.dataset.l;
    sel.value=area; render();
  });
  document.getElementById('chips').addEventListener('click',e=>{
    const b=e.target.closest('.chip'); if(!b) return;
    coal.has(b.dataset.k)?coal.delete(b.dataset.k):coal.add(b.dataset.k);
    render();
  });
  document.getElementById('reset').addEventListener('click',()=>{
    P.forEach((p,i)=>{
      p.v=DEF[i];
      rows.querySelector('.sl[data-i="'+i+'"]').value=Math.min(50,p.v);
      rows.querySelector('.nm[data-i="'+i+'"]').value=p.v.toFixed(2);
    });
    coal.clear(); area='DE'; sel.value='DE';
    render();
  });

  render();
})();
</script>
</body>
</html>
