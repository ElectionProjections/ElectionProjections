<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Bundestag seat projector</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fira+Sans+Condensed:wght@400;500;700&family=Fira+Sans:wght@400;500&family=Fira+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--paper:#F7F7F5;--rule:#D8D8D2;--rule-strong:#9A9A93;--ink:#161615;--ink-soft:#5C5C57;--ink-faint:#8E8E88;--card:#FFFFFF;--flag:#8A5A00}
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{background:var(--paper);color:var(--ink);font-family:"Fira Sans",system-ui,sans-serif;font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased}
  .wrap{max-width:1080px;margin:0 auto;padding:40px 24px 72px}
  header{border-bottom:2px solid var(--ink);padding-bottom:14px}
  .eyebrow{font-family:"Fira Mono",monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-faint);margin:0 0 6px}
  h1{font-family:"Fira Sans Condensed",sans-serif;font-weight:700;font-size:clamp(32px,5vw,48px);line-height:1.05;letter-spacing:-.01em;margin:0}
  .sub{color:var(--ink-soft);font-size:15px;max-width:64ch;margin:10px 0 0}
  .grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1.05fr);gap:40px;margin-top:32px;align-items:start}
  @media (max-width:860px){.grid{grid-template-columns:1fr;gap:32px}}
  .panel-label{font-family:"Fira Mono",monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-faint);border-bottom:1px solid var(--rule);padding-bottom:8px;margin:0 0 4px;display:flex;justify-content:space-between;align-items:baseline}
  .ballot{border-left:1px solid var(--rule);border-right:1px solid var(--rule)}
  .prow{display:grid;grid-template-columns:14px minmax(0,1fr) 88px 76px;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--rule)}
  .prow:first-child{border-top:1px solid var(--rule)}
  .prow.out{background:repeating-linear-gradient(135deg,transparent,transparent 6px,rgba(0,0,0,.022) 6px,rgba(0,0,0,.022) 12px)}
  .swatch{width:14px;height:14px;border-radius:2px}
  .pname{font-weight:500;font-size:15px;min-width:0}
  .pname small{display:block;font-weight:400;font-size:11px;color:var(--ink-faint);font-family:"Fira Mono",monospace;letter-spacing:.04em}
  .prow input[type=range]{grid-column:1/-1;width:100%;margin:6px 0 0;accent-color:var(--ink)}
  .num{display:flex;align-items:baseline;gap:3px;justify-self:end}
  .num input{width:62px;font-family:"Fira Mono",monospace;font-size:14px;text-align:right;border:1px solid var(--rule);border-radius:3px;padding:5px 6px;background:var(--card);color:var(--ink)}
  .num input:focus-visible{outline:2px solid var(--ink);outline-offset:1px}
  .num span{font-family:"Fira Mono",monospace;font-size:12px;color:var(--ink-faint)}
  .wk{font-family:"Fira Mono",monospace;font-size:10px;color:var(--ink-faint);justify-self:end;text-align:right;line-height:1.3}
  .wk b{display:block;font-weight:500;font-size:13px;color:var(--ink)}
  .wk.clause,.wk.clause b{color:var(--flag)}
  .tally{display:flex;justify-content:space-between;align-items:center;padding:12px 14px 0;font-family:"Fira Mono",monospace;font-size:12px;color:var(--ink-soft)}
  .tally.warn{color:#A32D2D}
  button.ghost{font-family:"Fira Mono",monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;background:none;border:1px solid var(--rule-strong);border-radius:3px;padding:5px 10px;color:var(--ink);cursor:pointer}
  button.ghost:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  button.ghost:focus-visible,select:focus-visible{outline:2px solid var(--ink);outline-offset:2px}
  .readout{display:flex;align-items:baseline;gap:10px;margin:2px 0 -6px}
  .readout b{font-family:"Fira Sans Condensed",sans-serif;font-size:40px;font-weight:700;line-height:1}
  .readout em{font-style:normal;font-family:"Fira Mono",monospace;font-size:12px;color:var(--ink-faint);letter-spacing:.06em}
  svg{display:block;width:100%;height:auto}
  circle.seat{transition:fill 160ms ease,opacity 160ms ease}
  @media (prefers-reduced-motion:reduce){circle.seat{transition:none}}
  .chips{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 14px}
  .chip{display:flex;align-items:center;gap:7px;border:1px solid var(--rule-strong);border-radius:3px;background:var(--card);padding:6px 10px;font-size:13px;cursor:pointer;font-family:"Fira Sans",sans-serif;color:var(--ink)}
  .chip[aria-pressed=true]{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  .chip:focus-visible{outline:2px solid var(--ink);outline-offset:2px}
  .chip i{width:9px;height:9px;border-radius:2px;display:block}
  .bar{position:relative;height:26px;background:var(--card);border:1px solid var(--rule);border-radius:3px;overflow:hidden}
  .fill{height:100%;display:flex}
  .fill span{display:block;height:100%}
  .maj{position:absolute;top:-5px;bottom:-5px;left:50%;width:2px;background:var(--ink)}
  .coalnote{font-family:"Fira Mono",monospace;font-size:12px;color:var(--ink-soft);margin:9px 0 0}
  .coalnote b{color:var(--ink)}
  select{font-family:"Fira Mono",monospace;font-size:11px;letter-spacing:.06em;text-transform:uppercase;background:var(--card);border:1px solid var(--rule-strong);border-radius:3px;padding:4px 8px;color:var(--ink);cursor:pointer}
  table.bd{width:100%;border-collapse:collapse;font-size:14px;table-layout:fixed}
  table.bd th{font-family:"Fira Mono",monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-faint);font-weight:400;text-align:right;padding:8px 6px;border-bottom:1px solid var(--rule)}
  table.bd th:first-child{text-align:left}
  table.bd td{padding:8px 6px;text-align:right;font-family:"Fira Mono",monospace;border-bottom:1px solid var(--rule)}
  table.bd td:first-child{text-align:left;font-family:"Fira Sans",sans-serif;font-weight:500;display:flex;align-items:center;gap:8px}
  table.bd td i{width:9px;height:9px;border-radius:2px;display:block;flex:none}
  table.bd td b{font-weight:500}
  table.bd tr.sum td{border-bottom:none;color:var(--ink-soft)}
  .clausebox{margin-top:18px;border:1px solid var(--rule);border-radius:3px;background:var(--card);padding:12px 14px}
  .clausebox p{margin:0;font-size:13px;color:var(--ink-soft);font-family:"Fira Mono",monospace}
  .clausebox p b{color:var(--ink)}
  .flip{margin-top:8px;font-size:13px;color:var(--ink-soft);line-height:1.5}
  .flip b{color:var(--ink);font-weight:500}
  .flip.flag b{color:var(--flag)}
  footer{margin-top:44px;border-top:1px solid var(--rule);padding-top:18px;font-size:13px;color:var(--ink-soft);max-width:78ch}
  footer h2{font-family:"Fira Sans Condensed",sans-serif;font-size:15px;font-weight:700;margin:0 0 6px}
  footer p{margin:0 0 10px}
  #mapwrap{max-width:290px;margin:10px auto 0}
  #map path{stroke:var(--paper);stroke-width:.9;cursor:pointer;transition:opacity 140ms ease}
  #map path:hover{opacity:.72}
  #map path.sel{stroke:var(--ink);stroke-width:1.8}
  #map:focus-visible{outline:2px solid var(--ink);outline-offset:2px}
  .maplab{font-family:"Fira Mono",monospace;font-size:11px;color:var(--ink-faint);text-align:center;margin:8px 0 0}
  .maplab b{color:var(--ink);font-weight:500}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0)}
</style>
</head>
